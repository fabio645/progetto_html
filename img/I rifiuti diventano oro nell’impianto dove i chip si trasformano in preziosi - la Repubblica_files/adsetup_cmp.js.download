          `,document.head.appendChild(e)),window._iub.csConfiguration.additionalPurposes=[{id:"sdkvideonielsen",defaultLabel:"SDK Video Nielsen",defaultDescription:"Permette ad Audicom S.r.l. (titolare del trattamento) di analizzare la fruizione video dei contenuti digitali da parte degli utenti, ai fini di rilevazione audience (i.e. per analisi e statistiche anonime e aggregate sui contenuti fruiti dagli utenti e sui volumi di consumo dei medesimi contenuti). Previo tuo consenso, Audicom utilizzerà maggiori informazioni per una rilevazione audience più precisa.",value:!1,readonly:!1},{id:"sdkvideoauditel",defaultLabel:"SDK Video Auditel",defaultDescription:"Permette ad Audicom S.r.l. (titolare del trattamento) di analizzare la fruizione video dei contenuti digitali da parte degli utenti, ai fini di rilevazione audience (i.e. per analisi e statistiche anonime e aggregate sui contenuti fruiti dagli utenti e sui volumi di consumo dei medesimi contenuti). Previo tuo consenso, Audicom utilizzerà maggiori informazioni per una rilevazione audience più precisa. Al momento, la rilevazione audience Audicom sulla base di tale strumento è in fase di sviluppo e le informazioni raccolte verranno utilizzate solo a fini interni (i.e. le analisi e statistiche anonime e aggregate sui contenuti fruiti dagli utenti e sui volumi di consumo dei medesimi contenuti non saranno distribuite).",value:!1,readonly:!1},{id:"sdktesto",defaultLabel:"SDK Testo",defaultDescription:"Permette ad Audicom S.r.l. (titolare del trattamento) di analizzare la fruizione dei contenuti digitali testuali da parte degli utenti, ai fini di rilevazione audience (i.e. per analisi e statistiche anonime e aggregate sui contenuti fruiti dagli utenti e sui volumi di consumo dei medesimi contenuti). Previo tuo consenso, Audicom utilizzerà maggiori informazioni per una rilevazione audience più precisa.",value:!1,readonly:!1},{id:"pairingping",defaultLabel:"Pairing Ping",defaultDescription:"Permette ad Audicom S.r.l. (titolare del trattamento), previo consenso, di rilevare l’informazione relativa alla presenza, sul dispositivo, di determinati cookie già precedentemente installati (i.e. cookie di terza parte denominati IMRID). Tale informazione consentirà ad Audicom di raccogliere informazioni utili a una rilevazione audience più precisa. Al momento, la rilevazione audience Audicom sulla base di tale strumento è in fase di sviluppo e le informazioni raccolte verranno utilizzate solo a fini interni (i.e. le analisi e statistiche anonime e aggregate sui contenuti fruiti dagli utenti e sui volumi di consumo dei medesimi contenuti non saranno distribuite).",value:!1,readonly:!1},{id:"rilevazionevolumetrica",defaultLabel:"Rilevazione volumetrica generale",defaultDescription:" ",value:!0,readonly:!1}],window.TLH_CookieWall.checkIfCookieWallIsActive()||(window._iub.csConfiguration.banner.html=`
            <div class="iubenda-cs-container" role="alertdialog" aria-describedby="iubenda-cs-paragraph" aria-labelledby="iubenda-cs-title">
                <div class="iubenda-cs-content" style="background-color: #EFEFEF !important;color: black !important;font-size: 16px !important;">
                    <div class="iubenda-cs-rationale">
                        <button type="button" class="iubenda-cs-close-btn" tabindex="0" role="button" aria-label="Chiudi questa informativa" style="border-radius: 55px !important; border: 1px solid rgb(119, 119, 119) !important; font-size: 16px !important; font-weight: bold !important; padding: 10px 20px !important; height: 34px !important; color: rgb(102, 102, 102) !important; visibility: visible;">Continua senza accettare</button>
                        <div class="iubenda-banner-content iubenda-custom-content iubenda-banner-content-padded" role="document">
                            %{banner_content}
                        </div>
                        <div class="iubenda-cs-counter" style="display: none;">Premi ancora per continuare 0/1</div>
                          <div class="iubenda-cs-opt-group" style="color:#EFEFEF!important;">
                              <div class="iubenda-cs-opt-group-custom">
                                  <button class="iubenda-cs-customize-btn ${n}" tabindex="0" role="button">Scegli e personalizza</button>
                              </div>
                              <div class="iubenda-cs-opt-group-consent">
                                  <button class="iubenda-cs-accept-btn iubenda-cs-btn-primary" tabindex="0" role="button">Accetta</button>
                              </div>
                          </div>
                        </div>
                    </div>
                </div>
            </div>
          `,window._iub.csConfiguration.banner.content=`
            <h2 id="iubenda-cs-title">Informativa</h2>
            <div id="iubenda-cs-paragraph" class="">
                <p class="iub-p"> Noi e terze parti selezionate utilizziamo cookie o tecnologie simili per finalità tecniche e, con il tuo consenso, anche per altre finalità come specificato nella <a href="https://scripts.gedidigital.it/corporate/privacy/nationalgeographic/cookie-policy.html"
                    role="button" target="_blank" rel="noopener" class="iubenda-cs-cookie-policy-lnk" aria-label="cookie policy - il link si apre in una nuova scheda">cookie policy</a>. </p>
                <p class="iub-p">Per quanto riguarda la pubblicità, noi e 1129
                    <button class="iubenda-vendor-list-link" data-iub-enabled="1">terze parti</button> selezionate, potremmo utilizzare <em>dati di geolocalizzazione precisi e l’identificazione attraverso la scansione del dispositivo</em>, al fine di <em>archiviare e/o accedere a informazioni su un dispositivo</em> e trattare
                    dati personali come i tuoi dati di utilizzo, per le seguenti
                    <button class="${n}">finalità pubblicitarie</button>: <em>pubblicità e contenuti personalizzati, misurazione delle prestazioni dei contenuti e degli annunci, ricerche sul pubblico, sviluppo di servizi.</em></p>
                <p class="iub-p">Puoi liberamente prestare, rifiutare o revocare il tuo consenso, in qualsiasi momento, accedendo al pannello delle preferenze. Se presti il tuo consenso, sarà valido solo su questo dominio. Il rifiuto del consenso può rendere non disponibili le relative
                    funzioni.</p>
                <p class="iub-p"></p>
                <p class="iub-p">Usa il pulsante “Accetta” per acconsentire. Chiudi questa informativa per continuare senza accettare.</p>
            </div>
